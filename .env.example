# AppWeaver INFINITY - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=appweaver
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=appweaver

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# GITHUB CONFIGURATION (Required for iOS Builds)
# ============================================
# Personal Access Token with repo permissions
GITHUB_TOKEN=ghp_your_github_token_here

# Repository for iOS builds (format: username/repo-name)
GITHUB_REPO=your-username/ios-build-repo

# GitHub username
GITHUB_USERNAME=your-github-username

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=AppWeaver INFINITY
APP_ENV=production
DEBUG=false
SECRET_KEY=your_super_secret_key_change_this_in_production

# ============================================
# BUILD CONFIGURATION
# ============================================
# Max concurrent builds
MAX_CONCURRENT_BUILDS=3

# Build timeout in seconds (20 minutes for iOS)
BUILD_TIMEOUT=1200

# Cleanup builds older than (in hours)
CLEANUP_AFTER_HOURS=24
