# NativX Production Environment Variables
# Rename to .env on the server

# --- APP CONFIGURATION ---
APP_ENV=production
DOMAIN=nativx.app

# --- SUPABASE (Auth & DB) ---
# Security & Auth (Local/Intranet Deployment)
JWT_SECRET_KEY=7b0a32491a921d8b6c4e5f7a0b3c2d1e0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5
# IMPORTANT: Set this to your server's IP address (e.g., http://192.168.1.10:8086)
# to avoid "Failed to fetch" errors when accessing from other computers.
NEXT_PUBLIC_API_URL=http://localhost:8086

# Supabase (Optional - Disabled for local auth)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- SECURITY ---

# --- DATABASE (Internal Docker Network) ---
POSTGRES_USER=NativX
POSTGRES_PASSWORD=Use_A_Strong_Password_Here
POSTGRES_DB=nativx
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://NativX:StrongPassword@db:5432/nativx

# --- REDIS (Internal) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- GITHUB (For iOS Builds) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/nativx-ios-builder
GITHUB_USERNAME=your-username
