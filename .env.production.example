# NativX Production Environment Variables
# Rename to .env on the server

# --- APP CONFIGURATION ---
APP_ENV=production
DOMAIN=nativx.app

# --- SUPABASE (Auth & DB) ---
# Use your production Supabase project keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- SECURITY ---
# Generate a strong random secret for sessions/hashing
SECRET_KEY=generate_a_strong_random_string_here_openssl_rand_hex_32

# --- STRIPE PAYMENTS (Live Mode) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_... (Get this from Stripe Dashboard after adding endpoint)

# --- DATABASE (Internal Docker Network) ---
POSTGRES_USER=NativX
POSTGRES_PASSWORD=Use_A_Strong_Password_Here
POSTGRES_DB=nativx
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://NativX:StrongPassword@db:5432/nativx

# --- REDIS (Internal) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- GITHUB (For iOS Builds) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/nativx-ios-builder
GITHUB_USERNAME=your-username
